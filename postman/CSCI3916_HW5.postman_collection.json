    {
      "name": "GET /movies - with reviews, sorted by avgRating",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Sorted by avgRating desc with reviews\", () => {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.be.an(\"array\");",
              "    pm.expect(json[0]).to.have.property(\"reviews\");",
              "    pm.expect(json[0]).to.have.property(\"avgRating\");",
              "    if (json.length > 1 && json[0].avgRating != null && json[1].avgRating != null) {",
              "        pm.expect(json[0].avgRating).to.be.at.least(json[1].avgRating);",
              "    }",
